# ──────────────────────────────────────────────────────
#  Mini Answer Evaluator — Environment Variables
# ──────────────────────────────────────────────────────
#  HOW TO USE:
#  1. Copy this file and rename it to .env
#  2. Replace the placeholder value with your real key
#  3. Never commit the .env file to GitHub
# ──────────────────────────────────────────────────────

# Groq API Key
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────
#  Model used (no need to change unless you want to)
# ──────────────────────────────────────────────────────
# Default: llama-3.3-70b-versatile
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
